---
import { Icon } from "astro-icon/components";

const { node, vendorName, path = "" } = Astro.props;
const children = Object.values(node.children || {});
const folderId = `folder-${vendorName}-${node.name}-${path}`.replace(/\s+/g, '-');
---

{node.type === 'folder' ? (
  <div class="flex flex-col gap-1 w-full">
    <button 
      class="folder-toggle collapsed flex items-center justify-between w-full p-2 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 transition-colors group cursor-pointer"
      data-folder-name={folderId}
    >
      <div class="flex items-center gap-2">
        <div class="chevron-wrapper transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400 group-hover:text-mint-500">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </div>
        <span class="text-[11px] font-bold text-zinc-600 dark:text-zinc-400 truncate max-w-[180px]">{node.name}</span>
      </div>
    </button>
    
    <div 
      class="folder-content collapsed flex flex-col gap-1 pl-3 border-l border-zinc-100 dark:border-zinc-800/50 ml-2 overflow-hidden transition-all duration-300" 
      id={`folder-${folderId}`} 
      style="max-height: 0px;"
    >
      {children.map((child: any) => (
        <Astro.self node={child} vendorName={vendorName} path={`${path}-${node.name}`} />
      ))}
    </div>
  </div>
) : (
  <button 
    data-path={node.path} 
    data-name={node.name} 
    class="sidebar-item flex items-start gap-2 p-1.5 rounded-lg text-left hover:bg-white dark:hover:bg-zinc-800 transition-all group cursor-pointer w-full"
  >
    <Icon name="info" class="text-zinc-400 group-hover:text-mint-500 mt-1 shrink-0 text-[10px]" />
    <span class="text-[10px] font-medium text-zinc-500 dark:text-zinc-400 group-hover:text-mint-400 leading-tight truncate">
      {node.name}
    </span>
  </button>
)}
