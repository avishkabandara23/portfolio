---
import { Icon } from "astro-icon/components";
import Heading from "../ui/Heading.astro";

const BADGES = [
  { name: "Nutanix", imageSrc: "/portfolio/icons/nutanix.png" },
  { name: "VMware", imageSrc: "/portfolio/icons/vmware.png" },
  { name: "Microsoft", imageSrc: "/portfolio/icons/microsoft.png" },
];

const safeBaseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<div class="flex flex-col gap-6 h-full">
  <div class="flex items-center gap-2">
    <div class="h-px grow bg-zinc-200 dark:bg-zinc-800"></div>
    <div class="flex items-center gap-2">
      <p
        class="text-[10px] font-black tracking-[.2em] uppercase bg-linear-to-r from-riptide-500 to-mint-400 dark:from-riptide-500 dark:to-mint-500 text-transparent bg-clip-text"
      >
        Verified Certs
      </p>
    </div>
    <div class="h-px grow bg-zinc-200 dark:bg-zinc-800"></div>
  </div>

  <div class="flex flex-col gap-8 items-center justify-center flex-1 py-4">
    {
      BADGES.map((badge) => (
        <div class="group relative flex flex-col items-center gap-2 transition-all duration-300 hover:scale-110">
          <div class="relative">
            <div class="absolute -inset-4 bg-mint-500/10 rounded-full blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <img
              src={badge.imageSrc}
              alt={badge.name}
              class="h-14 w-auto relative z-10 filter drop-shadow-md"
            />
          </div>
          <span class="text-[10px] font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
            {badge.name}
          </span>
        </div>
      ))
    }
  </div>
</div>
