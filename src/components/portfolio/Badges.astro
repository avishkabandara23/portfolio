---
const BADGES = [
  { name: "Lenovo", imageSrc: "/portfolio/icons/lenovo.png" },
  { name: "Nutanix", imageSrc: "/portfolio/icons/Nutanix-Logo.png" },
  { name: "Microsoft", imageSrc: "/portfolio/icons/Microsoft_Azure.svg.png" },
  { name: "Google", imageSrc: "/portfolio/icons/google-cloud-platform-logo-icon-2048x1824-pg4wzspq-1.webp" },
];

const safeBaseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<section id="certifications" class="py-12 bg-zinc-50/50 dark:bg-zinc-900/20 border-y border-zinc-200 dark:border-zinc-800/50 overflow-hidden scroll-m-16">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-16">
      <div class="flex items-center gap-4">
         <span class="text-[11px] font-black tracking-[.3em] uppercase text-mint-600 dark:text-mint-400 whitespace-nowrap">
            Certifications & Badges
         </span>
         <a href={`${safeBaseUrl}/certifications`} class="text-[10px] font-bold text-mint-500 hover:text-mint-400 underline decoration-1 underline-offset-4 transition-colors">
           View All &rarr;
         </a>
      </div>
      <div class="flex flex-wrap items-center gap-12 md:gap-20 opacity-80 hover:opacity-100 transition-opacity duration-500">
        {BADGES.map((badge) => (
          <div class="flex items-center group cursor-default">
            <img 
              src={badge.imageSrc} 
              alt={`${badge.name} Certification Badge`} 
              class="h-10 w-auto transition-all duration-300 group-hover:scale-110 filter drop-shadow-sm"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
