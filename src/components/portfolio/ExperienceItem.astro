---
interface Props {
  title: string;
  company: string;
  description: string;
  link?: string;
  date: string;
}

const { title, company, description, link, date } = Astro.props;
---

<div
  class="relative mx-12 pb-12 grid md:grid-cols-5 md:gap-10 before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 dark:before:border-white/15 before:content-['']"
>
  <div class="pb-12 md:col-span-2">
    <div class="sticky top-0">
      <span
        class="absolute -left-[42px] text-5xl text-mint-400 rounded-full drop-shadow-[0px_0px_8px_rgba(0,255,94,1)]"
        >&bull;</span
      >
      <h3
        
        class="text-xl font-bold text-mint-400"
      >
        {title}
      </h3>
      <h4 class="text-xl font-semibold text-zinc-600 dark:text-white">
        {company}
      </h4>
      <time datetime={date} class="text-sm text-zinc-600/80 dark:text-white/80">
        {date}
      </time>
    </div>
  </div>
  <div class="md:col-span-3">
    <div
      class="description-container relative flex flex-col gap-2 pb-4 text-zinc-600 dark:text-zinc-300 whitespace-pre-line text-justify max-md:line-clamp-4 transition-all duration-300"
    >
      {description}
    </div>
    <button
      class="expand-btn hidden max-md:flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-mint-400 mt-2 hover:text-mint-500 transition-colors"
    >
      <span>Read More</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-3 w-3 transform transition-transform duration-300"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="3"
          d="M19 9l-7 7-7-7"
        />
      </svg>
    </button>
  </div>
</div>

<script>
  function setupExpandButtons() {
    const containers = document.querySelectorAll('.description-container');
    
    containers.forEach(container => {
      const parent = container.parentElement;
      const btn = parent?.querySelector('.expand-btn');
      
      if (!btn || !container) return;

      // Only show button if text is actually truncated (on mobile)
      const isTruncated = container.scrollHeight > container.clientHeight;
      if (!isTruncated) {
        btn.classList.add('hidden');
      }

      btn.addEventListener('click', () => {
        const isExpanded = container.classList.contains('max-md:line-clamp-none');
        const span = btn.querySelector('span');
        const svg = btn.querySelector('svg');
        
        if (isExpanded) {
          container.classList.remove('max-md:line-clamp-none');
          container.classList.add('max-md:line-clamp-4');
          if (span) span.textContent = 'Read More';
          if (svg) svg.classList.remove('rotate-180');
        } else {
          container.classList.remove('max-md:line-clamp-4');
          container.classList.add('max-md:line-clamp-none');
          if (span) span.textContent = 'Show Less';
          if (svg) svg.classList.add('rotate-180');
        }
      });
    });
  }

  // Run on initial load and after any view transitions
  setupExpandButtons();
  document.addEventListener('astro:after-swap', setupExpandButtons);
</script>
