---
interface Props {
  lang: string;
  size?: "xs" | "md";
  linkEnabled?: boolean;
  imageSrc?: string;
}

const { size = "md", lang, linkEnabled = true, imageSrc } = Astro.props as Props;

const sizeMap = {
  xs: "size-4",
  md: "size-5",
};

const baseClasses = {
  container: [
    "flex items-center w-fit",
    "px-3 py-1.5 gap-1.5",
    "text-sm font-semibold leading-3",
    "bg-white shadow rounded-full",
    "transition-all duration-300 ease-in-out hover:bg-zinc-800 hover:text-white",
    "max-sm:px-2 max-sm:py-1 max-sm:text-xs",
  ].join(" "),
};

const getContainerClasses = () => {
  const textSize = lang.length > 10 ? "text-sm" : "text-base";
  return `${baseClasses.container} ${textSize}`;
};
---

{
  linkEnabled ? (
    <a
      class="cursor-pointer"
      href={`/blog/techs/${lang.toLowerCase().replace(/ /g, '-')}`}
      aria-label={`View articles about ${lang}`}
      role="link"
    >
      <span
        class={getContainerClasses()}
        role="presentation"
        aria-hidden="true"
      >
        {imageSrc && (
          <img
            src={imageSrc}
            alt={`${lang} icon`}
            class={`${sizeMap[size]} object-contain flex-shrink-0`}
          />
        )}
        {lang}
      </span>
    </a>
  ) : (
    <span
      class={`${getContainerClasses()} cursor-default`}
      role="presentation"
      aria-hidden="true"
    >
      {imageSrc && (
        <img
          src={imageSrc}
          alt={`${lang} icon`}
          class={`${sizeMap[size]} object-contain flex-shrink-0`}
        />
      )}
      {lang}
    </span>
  )
}
